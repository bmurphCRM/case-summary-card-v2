{
    "trailingComma": "none",
    "tabWidth": 4,
    "printWidth": 120,
    "singleQuote": true,
    "overrides": [
        {
            "files": "**/lwc/**/*.html",
            "options": { "parser": "lwc" }
        },
        {
            "files": "*.{cmp,page,component}",
            "options": { "parser": "html" }
        },
        {
            "files": "*.{cls,trigger,apex}",
            "options": { "printWidth": 140 }
        },
        {
            "files": "*.{json,md}",
            "options": { "tabWidth": 2 }
        }
    ]
}
